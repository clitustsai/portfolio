    { "source": "/api/google-callback", "destination": "/api/auth.js" },
    { "source": "/api/auth/:path*", "destination": "/api/auth.js" },
    { "source": "/api/auth", "destination": "/api/auth.js" },
    { "source": "/api/comments/:path*", "destination": "/api/comments.js" },
    { "source": "/api/comments", "destination": "/api/comments.js" },
    { "source": "/api/messages/:path*", "destination": "/api/messages.js" },
    { "source": "/api/messages", "destination": "/api/messages.js" },
    { "source": "/api/blog/:path*", "destination": "/api/blog.js" },
    { "source": "/api/chat/:path*", "destination": "/api/chat.js" },
    { "source": "/api/chat-ai", "destination": "/api/chat.js" },
    { "source": "/api/ads/ai-fill", "destination": "/api/ads.js" },
    { "source": "/api/ads/:path*", "destination": "/api/ads.js" },
    { "source": "/api/ads", "destination": "/api/ads.js" },
    { "source": "/api/pr-posts/:path*", "destination": "/api/ads.js" },
    { "source": "/api/pr-posts", "destination": "/api/ads.js" },
    { "source": "/api/health", "destination": "/api/health.js" }
