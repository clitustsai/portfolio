{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "*.json", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "*.jpg", "use": "@vercel/static" },
    { "src": "*.svg", "use": "@vercel/static" },
    { "src": "*.ico", "use": "@vercel/static" },
    { "src": "*.webp", "use": "@vercel/static" },
    { "src": "*.webmanifest", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health.js" },
    { "source": "/api/stats", "destination": "/api/stats.js" },
    { "source": "/api/comments/:path*", "destination": "/api/comments.js" },
    { "source": "/api/comments", "destination": "/api/comments.js" },
    { "source": "/api/messages/:path*", "destination": "/api/messages.js" },
    { "source": "/api/messages", "destination": "/api/messages.js" },
    { "source": "/api/projects/:path*", "destination": "/api/projects.js" },
    { "source": "/api/auth/:path*", "destination": "/api/auth.js" },
    { "source": "/api/blog/:path*", "destination": "/api/blog.js" },
    { "source": "/api/chat/:path*", "destination": "/api/chat.js" },
    { "source": "/api/subscription/:path*", "destination": "/api/subscription.js" },
    { "source": "/api/chat-ai", "destination": "/api/aichat.js" }
  ]
}
