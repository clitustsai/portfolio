{
  "version": 2,
  "builds": [
    { "src": "api/_db.js", "use": "@vercel/node" },
    { "src": "api/_auth.js", "use": "@vercel/node" },
    { "src": "api/health.js", "use": "@vercel/node" },
    { "src": "api/stats.js", "use": "@vercel/node" },
    { "src": "api/auth.js", "use": "@vercel/node" },
    { "src": "api/comments.js", "use": "@vercel/node" },
    { "src": "api/messages.js", "use": "@vercel/node" },
    { "src": "api/projects.js", "use": "@vercel/node" },
    { "src": "api/blog.js", "use": "@vercel/node" },
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "api/subscription.js", "use": "@vercel/node" },
    { "src": "api/aichat.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/stats", "dest": "/api/stats.js" },
    { "src": "/api/auth/(.*)", "dest": "/api/auth.js" },
    { "src": "/api/comments/(.*)", "dest": "/api/comments.js" },
    { "src": "/api/comments", "dest": "/api/comments.js" },
    { "src": "/api/messages/(.*)", "dest": "/api/messages.js" },
    { "src": "/api/messages", "dest": "/api/messages.js" },
    { "src": "/api/projects/(.*)", "dest": "/api/projects.js" },
    { "src": "/api/blog/(.*)", "dest": "/api/blog.js" },
    { "src": "/api/chat/(.*)", "dest": "/api/chat.js" },
    { "src": "/api/subscription/(.*)", "dest": "/api/subscription.js" },
    { "src": "/api/chat-ai", "dest": "/api/aichat.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
