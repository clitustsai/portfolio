{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "dist/**", "use": "@vercel/static" },
    { "src": "img/**", "use": "@vercel/static" },
    { "src": "files/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/google-login", "dest": "/api/auth.js" },
    { "src": "/api/google-callback", "dest": "/api/auth.js" },
    { "src": "/api/auth(.*)", "dest": "/api/auth.js" },
    { "src": "/api/comments(.*)", "dest": "/api/comments.js" },
    { "src": "/api/messages(.*)", "dest": "/api/messages.js" },
    { "src": "/api/blog(.*)", "dest": "/api/blog.js" },
    { "src": "/api/chat(.*)", "dest": "/api/chat.js" },
    { "src": "/api/chat-ai", "dest": "/api/chat.js" },
    { "src": "/api/tools(.*)", "dest": "/api/tools.js" },
    { "src": "/api/subscription(.*)", "dest": "/api/subscription.js" },
    { "src": "/api/ads(.*)", "dest": "/api/ads.js" },
    { "src": "/api/pr-posts(.*)", "dest": "/api/ads.js" },
    { "src": "/api/live(.*)", "dest": "/api/live.js" },
    { "src": "/api/coins(.*)", "dest": "/api/coins.js" },
    { "src": "/api/user(.*)", "dest": "/api/auth.js" },
    { "src": "/api/health", "dest": "/api/health.js" }
  ]
}
